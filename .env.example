# Sanity (Journal)
NEXT_PUBLIC_SANITY_PROJECT_ID=sc7b74ps
NEXT_PUBLIC_SANITY_DATASET=production

SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token
SHOPIFY_API_VERSION=2026-01

# Customer Account API (Headless channel → Customer Account API settings)
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=your_customer_account_client_id

# Public HTTPS URL where this Next.js app is deployed (must match Shopify callback URLs).
# Example: https://royal-cashmere.vercel.app
SHOPIFY_APP_URL=https://royal-cashmere.vercel.app

# Storefront API scopes required for cart:
# unauthenticated_read_product_listings
# unauthenticated_read_checkouts
# unauthenticated_write_checkouts

# Shopify Admin setup for customer login:
# 1. Settings → Customer accounts → enable Customer accounts
# 2. Sales channels → Headless → Customer Account API
# 3. Callback URL: https://YOUR_DEPLOYED_DOMAIN/api/auth/callback
# 4. Javascript origin: https://YOUR_DEPLOYED_DOMAIN
# 5. Logout URL: https://YOUR_DEPLOYED_DOMAIN/

# Contact form (Resend — https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
CONTACT_TO_EMAIL=contact@royal-cashmere.eu
# Must use a verified sender domain in production
CONTACT_FROM_EMAIL=Royal Cashmere <contact@royal-cashmere.eu>
